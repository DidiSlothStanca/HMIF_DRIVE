<?php
/**
 * HMIF Drive - Database Configuration Template
 * * PETUNJUK:
 * 1. Rename file ini menjadi 'db.php'
 * 2. Isi variabel di bawah sesuai dengan kredensial database server Anda.
 * 3. JANGAN PERNAH mengupload file 'db.php' yang asli ke repositori publik.
 */

$host = "localhost";
$user = "YOUR_DATABASE_USER";     // Contoh: root
$pass = "YOUR_DATABASE_PASSWORD"; // Isi password database Anda
$db   = "YOUR_DATABASE_NAME";     // Contoh: hmif_db

$conn = mysqli_connect($host, $user, $pass, $db);

if (!$conn) {
    // Pesan error umum agar tidak membocorkan detail teknis ke publik
    die("Maaf, terjadi gangguan koneksi ke sistem.");
}

/**
 * Security Headers
 * Menjaga aplikasi dari Clickjacking dan XSS
 */
header("X-Frame-Options: DENY");
header("X-XSS-Protection: 1; mode=block");
header("X-Content-Type-Options: nosniff");
header("Referrer-Policy: strict-origin-when-cross-origin");

// Mengatur charset agar mendukung emoji dan karakter khusus secara aman
mysqli_set_charset($conn, "utf8mb4");
?>
